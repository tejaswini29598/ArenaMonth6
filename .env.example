# Environment Configuration
# Copy this file to .env and update with your values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=enterprise_db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch Configuration
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# Application Configuration
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_PORT=8080
APP_TIMEOUT=30000

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-change-me
JWT_EXPIRATION=86400
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Encryption
ENCRYPTION_KEY=your-encryption-key-min-32-characters-long-change-me
ENCRYPTION_ALGORITHM=AES-256-GCM

# Vault Configuration
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your-vault-token
VAULT_NAMESPACE=enterprise

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8080
REACT_APP_API_TIMEOUT=30000
REACT_APP_ENVIRONMENT=development

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3001

# Elasticsearch Kibana
KIBANA_PORT=5601

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@enterprise-platform.com

# Cloud Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

GCP_PROJECT_ID=your-project-id
GCP_CREDENTIALS_PATH=/path/to/credentials.json

# Security Configuration
TLS_ENABLED=true
TLS_CERT_PATH=/etc/certs/tls.crt
TLS_KEY_PATH=/etc/certs/tls.key

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# Cors Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# Feature Flags
FEATURE_NEW_DASHBOARD=true
FEATURE_ADVANCED_SEARCH=false
FEATURE_BETA_FEATURES=false

# Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Platform is under maintenance
